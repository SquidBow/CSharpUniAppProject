<Window x:Class="MoneyManager.WpfUI.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoneyManager.WpfUI"
        mc:Ignorable="d"
        Title="AddTransactionWindow" Height="450" Width="800">
    <StackPanel>
            <TextBlock Text="Sum:"/>
            <TextBox Name="SumInput"/>

            <TextBlock Text="Category:"/>
            <ComboBox Name="TypeSelector"/>

            <TextBlock Text="Description:"/>
            <TextBox Name="DescInput"/>

            <Button Content="Add" Width="60" Click="AddButton"/>
        </StackPanel>
</Window>
