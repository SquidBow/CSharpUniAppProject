<Page x:Class="MoneyManager.WpfUI.AddWalletPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddWalletPage">
    
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Width="200">
            <TextBlock Text="Wallet Name:"/>
            <TextBox Text="{Binding WalletName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Currency:"/>
            <ComboBox ItemsSource="{Binding CurrenciesList}" 
                      SelectedItem="{Binding SelectedCurrency}"/>

            <Button Content="Save" Command="{Binding SaveCommand}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Page>