<Page x:Class="MoneyManager.WpfUI.AddWalletPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MoneyManager.WpfUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddWalletPage">

    <Grid>
        <StackPanel>
            <TextBlock Text="Wallet Name:"/>
            <TextBox Name="WalletName"/>

            <TextBlock Text="Currency:"/>
            <ComboBox Name="CurrencySelector"/>

            <Button Content="Add" Width="60" HorizontalAlignment="Center" Click="AddButton"/>
        </StackPanel>
    </Grid>
</Page>
