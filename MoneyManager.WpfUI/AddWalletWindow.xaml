<Window x:Class="MoneyManager.WpfUI.AddWalletWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoneyManager.WpfUI"
        mc:Ignorable="d"
        Title="AddWalletWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBlock Text="Wallet Name:"/>
            <TextBox Name="WalletName"/>

            <TextBlock Text="Currency:"/>
            <ComboBox Name="CurrencySelector"/>

            <Button Content="Add" Width="60" HorizontalAlignment="Center" Click="AddButton"/>
        </StackPanel>
    </Grid>
</Window>
