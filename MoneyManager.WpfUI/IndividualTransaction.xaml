<Page x:Class="MoneyManager.WpfUI.IndividualTransaction"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="IndividualTransaction">

    <StackPanel>
        <TextBlock Text="{Binding Id, StringFormat='ID: {0}'}" FontWeight="Bold" />
        <TextBlock Text="{Binding Sum, StringFormat='Sum: {0}'}" FontWeight="Bold" />
        <TextBlock Text="{Binding Type, StringFormat='Type: {0}'}" FontWeight="Bold" />
        <TextBlock Text="{Binding Description, StringFormat='Description: {0}'}" FontWeight="Bold" />
        <TextBlock Text="{Binding Date, StringFormat='Date: {0:yyyy-MM-dd}'}" FontWeight="Bold" />

        <Button Content="Back" Command="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=DataContext.BackCommand}" Visibility="Collapsed"/>
    </StackPanel>
</Page>