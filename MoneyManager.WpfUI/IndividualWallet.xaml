<Page x:Class="MoneyManager.WpfUI.IndividualWallet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="IndividualWallet">
    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Details.Name}" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding Details.Balance, StringFormat='Balance: {0}'}"/>
            <TextBlock Text="{Binding Details.Currency}"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*, *">
            <Button Grid.Column="0" Content="+" Command="{Binding AddTransactionCommand}"/>
            <Button Grid.Column="1" Content="-" 
                    Command="{Binding RemoveTransactionCommand}"
                    CommandParameter="{Binding SelectedItem.Id, ElementName=TransactionList}"/>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="30, *, *, *, *">
            <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Sum" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Type" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="Description" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="Date of creation" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Grid>

        <ListBox Grid.Row="3" x:Name="TransactionList" 
                 ItemsSource="{Binding Details.Transactions}" 
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Background="Transparent">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding DataContext.ShowTransactionDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>
                        <Grid ColumnDefinitions="30, *, *, *, *">
                            <TextBlock Grid.Column="0" Text="{Binding Id}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Sum}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Type}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Description}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding Date, StringFormat='d'}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="4" Content="Back to Wallets" Command="{Binding BackCommand}"/>
    </Grid>
</Page>