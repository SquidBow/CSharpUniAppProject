<Page x:Class="MoneyManager.WpfUI.IndividualWallet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="IndividualWallet">
    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, *, Auto">
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Details.Name}" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding Details.Balance, StringFormat='Balance: {0}'}"/>
            <TextBlock Text="{Binding Details.Currency}"/>
        </StackPanel>

        <Grid ColumnDefinitions="*" Grid.Row="1">
            <TextBlock Text="Filter By Description" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
        </Grid>

        <Grid ColumnDefinitions="*" Grid.Row="2">
            <TextBox TextChanged="UpdateShownTransactions"/>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="*, *, *">
            <Button Grid.Column="0" Content="+" Command="{Binding AddTransactionCommand}"/>
            <Button Grid.Column="1" Content="Edit" 
                    Command="{Binding EditTransactionCommand}"
                    CommandParameter="{Binding SelectedItem.Id, ElementName=TransactionList}"/>
            <Button Grid.Column="2" Content="-" 
                    Command="{Binding RemoveTransactionCommand}"
                    CommandParameter="{Binding SelectedItem.Id, ElementName=TransactionList}"/>
        </Grid>


        <Grid Grid.Row="4" ColumnDefinitions="30, *, *, *, *">
            <Button Grid.Column="0" Content="ID" FontWeight="Bold" HorizontalAlignment="Center" Click="SortById"/>
            <Button Grid.Column="1" Content="Sum" FontWeight="Bold" HorizontalAlignment="Center" Click="SortBySum"/>
            <Button Grid.Column="2" Content="Type" FontWeight="Bold" HorizontalAlignment="Center" Click="SortByType"/>
            <Button Grid.Column="3" Content="Description" FontWeight="Bold" HorizontalAlignment="Center" Click="SortByDescription"/>
            <Button Grid.Column="4" Content="Date of creation" FontWeight="Bold" HorizontalAlignment="Center" Click="SortByDate"/>
        </Grid>

        <ListBox Grid.Row="5" x:Name="TransactionList" 
                 ItemsSource="{Binding ShownTransactions}" 
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Background="Transparent">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding DataContext.ShowTransactionDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>
                        <Grid ColumnDefinitions="30, *, *, *, *">
                            <TextBlock Grid.Column="0" Text="{Binding Id}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Sum}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Type}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Description}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding Date, StringFormat='d'}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>