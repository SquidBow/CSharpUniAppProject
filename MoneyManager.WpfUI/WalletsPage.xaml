<Page x:Class="MoneyManager.WpfUI.WalletsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MoneyManager.WpfUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WalletsPage">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid ColumnDefinitions="*, *" Margin="10" Grid.Row="0">
            <Button Grid.Column="0" Click="AddButton">+</Button>
            <Button Grid.Column="1" Click="SubButton">-</Button>
        </Grid>

        <Grid ColumnDefinitions="18, 30, *, *, 10" Margin="0,0,0,0" Grid.Row="1">
            <TextBlock Grid.Column="1" Text="ID" FontWeight="ExtraBold" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="2" Text="Name" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="Currency" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
        </Grid>

        <ListBox Grid.Row="2" Name="WalletsList" HorizontalContentAlignment="Stretch" MouseDoubleClick="ShowIndividualWallet">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Padding="10">
                        <Grid ShowGridLines="False" ColumnDefinitions="30, *, *">
                            <TextBlock Grid.Column="0" Text="{Binding Id}" FontWeight="Bold" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Currency}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
