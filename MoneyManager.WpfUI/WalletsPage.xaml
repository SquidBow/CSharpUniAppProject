<Page x:Class="MoneyManager.WpfUI.WalletsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WalletsPage">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *">
        <Grid ColumnDefinitions="*" Grid.Row="0">
            <TextBlock Text="Filter By Name" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
        </Grid>


        <Grid ColumnDefinitions="*" Grid.Row="1">
            <TextBox TextChanged="UpdateShownWallets"/>
        </Grid>

        <Grid ColumnDefinitions="*, *, *" Grid.Row="2">
            <Button Grid.Column="0" Content="+" Command="{Binding AddCommand}"/>
            <Button Grid.Column="1" Content="Edit" 
                    Command="{Binding EditCommand}" 
                    CommandParameter="{Binding SelectedItem, ElementName=WalletsList}"/>
            <Button Grid.Column="2" Content="-" 
                    Command="{Binding RemoveCommand}" 
                    CommandParameter="{Binding SelectedItem.Id, ElementName=WalletsList}"/>
        </Grid>

        <Grid ColumnDefinitions="30, *, *" Grid.Row="3">
            <Button Grid.Column="0" Content="ID" FontWeight="ExtraBold" HorizontalAlignment="Center" Click="SortById"/>
            <Button Grid.Column="1" Content="Name" FontWeight="ExtraBold" HorizontalAlignment="Center" Click="SortByName"/>
            <Button Grid.Column="2" Content="Balance" FontWeight="ExtraBold" HorizontalAlignment="Center" Click="SortByBalance"/>
        </Grid>

        <ListBox Grid.Row="4" x:Name="WalletsList" ItemsSource="{Binding ShownWallets}" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Background="Transparent">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>
                        <Grid ColumnDefinitions="30, *, *">
                            <TextBlock Grid.Column="0" Text="{Binding Id}" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Balance}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>