<Page x:Class="MoneyManager.WpfUI.WalletsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WalletsPage">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid ColumnDefinitions="*, *" Grid.Row="0">
            <Button Grid.Column="0" Content="+" Command="{Binding AddCommand}"/>
            <Button Grid.Column="1" Content="-" 
                    Command="{Binding RemoveCommand}" 
                    CommandParameter="{Binding SelectedItem.Id, ElementName=WalletsList}"/>
        </Grid>

        <Grid ColumnDefinitions="30, *, *" Grid.Row="1">
            <TextBlock Grid.Column="0" Text="ID" FontWeight="ExtraBold" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1" Text="Name" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Balance" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
        </Grid>

        <ListBox Grid.Row="2" x:Name="WalletsList" ItemsSource="{Binding Wallets}" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Background="Transparent">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>
                        <Grid ColumnDefinitions="30, *, *">
                            <TextBlock Grid.Column="0" Text="{Binding Id}" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Balance}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>